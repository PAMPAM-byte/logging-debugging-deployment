{
    "info": {
      "name": "MyAPI – Full Verification",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      { "key": "baseUrl", "value": "http://localhost:3000" },
      { "key": "newItemId", "value": "" },
      { "key": "newUserId", "value": "" },
      { "key": "newOrderId", "value": "" }
    ],
    "item": [
      {
        "name": "Health check",
        "request": { "method": "GET", "url": "{{baseUrl}}/health" },
        "event": [{ "listen": "test", "script": { "exec": [
          "pm.test('Status 200', () => pm.response.to.have.status(200));",
          "pm.test('App name present', () => {",
          "  pm.expect(pm.response.json()).to.have.property('app');",
          "});"
        ]}}]
      },
      {
        "name": "── ITEMS ──",
        "item": [
          {
            "name": "GET all items",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/items" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}}]
          },
          {
            "name": "GET items filtered by category",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/items?category=basic" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('All results are basic', () => {",
              "  pm.response.json().forEach(i => pm.expect(i.category).to.eql('basic'));",
              "});"
            ]}}]
          },
          {
            "name": "GET single item",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/items/1" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));"
            ]}}]
          },
          {
            "name": "POST create item",
            "request": {
              "method": "POST", "url": "{{baseUrl}}/api/items",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Widget D\",\"price\":49.99,\"category\":\"premium\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Saved with correct name', () => pm.expect(pm.response.json().name).to.eql('Widget D'));",
              "pm.collectionVariables.set('newItemId', pm.response.json().id);"
            ]}}]
          },
          {
            "name": "POST item missing fields",
            "request": {
              "method": "POST", "url": "{{baseUrl}}/api/items",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Incomplete\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('Has error field', () => pm.expect(pm.response.json()).to.have.property('error'));"
            ]}}]
          },
          {
            "name": "PUT update item",
            "request": {
              "method": "PUT", "url": "{{baseUrl}}/api/items/{{newItemId}}",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Widget D Updated\",\"price\":59.99,\"category\":\"premium\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.eql('Widget D Updated'));"
            ]}}]
          },
          {
            "name": "DELETE item",
            "request": { "method": "DELETE", "url": "{{baseUrl}}/api/items/{{newItemId}}" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}}]
          },
          {
            "name": "GET 404 item",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/items/9999" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 404', () => pm.response.to.have.status(404));"
            ]}}]
          }
        ]
      },
      {
        "name": "── USERS ──",
        "item": [
          {
            "name": "GET all users",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/users" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}}]
          },
          {
            "name": "GET users filtered by role",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/users?role=admin" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('All results are admin', () => {",
              "  pm.response.json().forEach(u => pm.expect(u.role).to.eql('admin'));",
              "});"
            ]}}]
          },
          {
            "name": "POST create user",
            "request": {
              "method": "POST", "url": "{{baseUrl}}/api/users",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Dan Brown\",\"email\":\"dan@example.com\",\"role\":\"user\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('newUserId', pm.response.json().id);"
            ]}}]
          },
          {
            "name": "POST duplicate email",
            "request": {
              "method": "POST", "url": "{{baseUrl}}/api/users",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Dupe\",\"email\":\"dan@example.com\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 409 on duplicate email', () => pm.response.to.have.status(409));"
            ]}}]
          },
          {
            "name": "PUT update user",
            "request": {
              "method": "PUT", "url": "{{baseUrl}}/api/users/{{newUserId}}",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"name\":\"Dan B Updated\",\"email\":\"dan@example.com\",\"role\":\"admin\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Role updated to admin', () => pm.expect(pm.response.json().role).to.eql('admin'));"
            ]}}]
          },
          {
            "name": "DELETE user",
            "request": { "method": "DELETE", "url": "{{baseUrl}}/api/users/{{newUserId}}" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}}]
          }
        ]
      },
      {
        "name": "── ORDERS ──",
        "item": [
          {
            "name": "GET all orders",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/orders" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
            ]}}]
          },
          {
            "name": "GET orders filtered by status",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/orders?status=pending" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('All results are pending', () => {",
              "  pm.response.json().forEach(o => pm.expect(o.status).to.eql('pending'));",
              "});"
            ]}}]
          },
          {
            "name": "GET orders filtered by userId",
            "request": { "method": "GET", "url": "{{baseUrl}}/api/orders?userId=1" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]}}]
          },
          {
            "name": "POST create order",
            "request": {
              "method": "POST", "url": "{{baseUrl}}/api/orders",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"userId\":1,\"itemId\":2,\"quantity\":2}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Status defaults to pending', () => pm.expect(pm.response.json().status).to.eql('pending'));",
              "pm.collectionVariables.set('newOrderId', pm.response.json().id);"
            ]}}]
          },
          {
            "name": "PATCH order status",
            "request": {
              "method": "PATCH", "url": "{{baseUrl}}/api/orders/{{newOrderId}}/status",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"status\":\"shipped\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Status updated to shipped', () => pm.expect(pm.response.json().status).to.eql('shipped'));"
            ]}}]
          },
          {
            "name": "PATCH invalid order status",
            "request": {
              "method": "PATCH", "url": "{{baseUrl}}/api/orders/{{newOrderId}}/status",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\"status\":\"exploded\"}" }
            },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 400 on invalid status', () => pm.response.to.have.status(400));"
            ]}}]
          },
          {
            "name": "DELETE order",
            "request": { "method": "DELETE", "url": "{{baseUrl}}/api/orders/{{newOrderId}}" },
            "event": [{ "listen": "test", "script": { "exec": [
              "pm.test('Status 204', () => pm.response.to.have.status(204));"
            ]}}]
          }
        ]
      }
    ]
  }